# Node API URLs per network
# Set these to your public node's API endpoints
# Examples:
# VITE_NODE_API_URL_MAINNET=https://mainnet.your-domain.com/api
# VITE_NODE_API_URL_TESTNET=https://testnet.your-domain.com/api
VITE_NODE_API_URL_MAINNET=
VITE_NODE_API_URL_TESTNET=
VITE_PUBLIC_NODE_APIS=
VITE_CORE_API_URL_TESTNET=http://127.0.0.1:5100/api
VITE_CORE_API_URL=http://127.0.0.1:5100/api

# Legacy/default fallback (used if per-network URLs are not set)
VITE_NODE_API_URL=http://localhost:5100/api
